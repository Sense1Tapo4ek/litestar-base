# Application
APP_NAME=litestar-base
APP_ENV=dev

# ASGI server
APP_HOST=127.0.0.1
APP_PORT=8000
APP_WORKERS=1
# Seconds uvicorn waits for inflight requests on SIGTERM before forcing close.
# Must be < orchestrator hard timeout (K8s default 30s) so the lifespan stop
# (worker drain, event-bus flush) gets to run before SIGKILL.
APP_SHUTDOWN_TIMEOUT_S=25

# Paths
# Persistent application data, sibling of src/. Logs live under ${VOLUME_PATH}/logs.
VOLUME_PATH=./storage

# Process runtime files such as pidfiles. Defaults to /tmp/${APP_NAME}.
# RUNTIME_PATH=/tmp/litestar-base

# Logging (admin/log subsystem) — all settings owned by AdminLogConfig.
# Read by: src/admin/log/config.py
#LOG_RETENTION_DAYS=7
#LOG_BATCH_SIZE=100
#LOG_BATCH_TIMEOUT_MS=100
#LOG_SSE_QUEUE_SIZE=100
#LOG_CLEANUP_INTERVAL_HOURS=24
#LOG_TAIL_SIZE=200
#LOG_HISTORY_CHUNK=200
#LOG_DB_READER_COUNT=4
# SSE tail polls log table when no new rows arrive. Higher = less DB load
# under many concurrent live tails; lower = lower max latency to first row.
#LOG_STREAM_POLL_INTERVAL_S=3.0
# Hard ceiling on a single SQL LIMIT. Tail/history chunk sizes must be
# below this value, otherwise the repo rejects the query (4xx).
#LOG_MAX_LIMIT=5000

# Snitchbot — Telegram crash and anomaly reporter.
# Disabled by default so a fresh checkout starts without Telegram credentials.
# To enable: comment out SNITCHBOT_DISABLED and fill TOKEN + CHAT_ID.
SNITCHBOT_DISABLED=1
#SNITCHBOT_TOKEN=
#SNITCHBOT_CHAT_ID=


# ─── Security headers ────────────────────────────────────────────────────────
# Content-Security-Policy attached to every HTTP response. Override to tighten
# (e.g., remove 'unsafe-inline' once inline styles are gone) or to whitelist
# additional CDNs/origins for your front-end.
#SECURITY_CSP=default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
# Strict-Transport-Security toggle (max-age=2y, includeSubDomains). Off by
# default — enabling on http://localhost poisons the browser cache.
#SECURITY_HSTS_ENABLED=0

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Bearer token granting Role.ADMIN. Empty value disables auth in dev (warning
# logged at startup). Required when APP_ENV=PROD (validated by RootConfig).
# Generate one with:  openssl rand -hex 32
AUTH_ADMIN_TOKEN=

# ─── Build info ───────────────────────────────────────────────────────────────
# Reported via /health and admin dashboard. Populated by CI/Docker build:
#   GIT_COMMIT_SHA=$(git rev-parse HEAD)
#   GIT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
#   GIT_DIRTY=$([ -n "$(git status --porcelain)" ] && echo 1 || echo 0)
# In dev with a checked-out repo these are auto-resolved via `git` subprocess —
# no need to set them. In Docker without git installed: env vars are required,
# otherwise commit_sha falls back to "unknown".
#GIT_COMMIT_SHA=
#GIT_BRANCH=
#GIT_DIRTY=0
